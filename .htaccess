RewriteEngine On

# Staging-only anti-indexing. These rules are inert on the production host.
<IfModule mod_setenvif.c>
  SetEnvIf Host "^seashell-okapi-889488\.hostingersite\.com(?::[0-9]+)?$" mgw_staging_host=1
</IfModule>
<IfModule mod_headers.c>
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=mgw_staging_host
</IfModule>

# Serve the staging robots policy only on the staging host.
RewriteCond %{HTTP_HOST} ^seashell-okapi-889488\.hostingersite\.com(?::[0-9]+)?$ [NC]
RewriteRule ^robots\.txt$ ops/staging/robots.txt [L]

# Keep the Telegram Mini App and bot completely independent from the public site.
RewriteRule ^(?:app|bot)(?:/|$) - [L]

# Do not expose the internal physical site directory as a second public URL.
RewriteCond %{THE_REQUEST} \s/+site(?:[/?\s]) [NC]
RewriteRule ^site(?:/|$) - [F,L]

# Public root assets keep their existing URLs.
RewriteRule ^favicon\.ico$ favicon.svg [L]
RewriteRule ^legal\.css$ site/legal/legal.css [L]

# Russian-only main landing page.
RewriteRule ^$ site/landing/landing-v18.php [L]

# Russian-only blog pages. Static assets retain their existing URLs.
RewriteRule ^blog/?$ site/russian-page.php?page=blog [L,QSA]
RewriteRule ^blog/(tic-tac-toe-online|telegram-mini-app-games|telegram-games-with-friends|upcoming-games|gold-room|bot-and-match-coins)/?$ site/russian-page.php?page=$1 [L,QSA]
RewriteRule ^blog/(.+)$ site/blog/$1 [L]

# Russian-only legal pages.
RewriteRule ^privacy/?$ site/russian-page.php?page=privacy [L,QSA]
RewriteRule ^cookies/?$ site/russian-page.php?page=cookies [L,QSA]
RewriteRule ^terms/?$ site/russian-page.php?page=terms [L,QSA]
